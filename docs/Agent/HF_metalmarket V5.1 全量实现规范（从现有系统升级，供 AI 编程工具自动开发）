## 通知分发器

```python
class Notifier:
    def __init__(self):
        self.channels = {
            'system': SystemChannel(),
            'wechat': WeChatChannel(),
            'sms': SMSChannel(),
        }

    def send(self, notification_type, recipient, message, channels=None):
        target_channels = channels or self._get_default_channels(notification_type)
        results = {}
        for ch_name in target_channels:
            channel = self.channels.get(ch_name)
            if channel:
                try:
                    result = channel.send(recipient, message)
                    results[ch_name] = result
                except Exception as e:
                    results[ch_name] = {'status': 'failed', 'error': str(e)}
        self._log_notification(notification_type, recipient, message, results)
        return results

    def _get_default_channels(self, notification_type):
        # 从规则配置读取默认通知渠道
        channel_map = {
            'overdue_reminder': ['system', 'wechat'],
            'contract_expiring': ['system', 'wechat'],
            'daily_report': ['system'],
            'monthly_report': ['system'],
            'urgent_alert': ['system', 'wechat', 'sms'],
        }
        return channel_map.get(notification_type, ['system'])
```

