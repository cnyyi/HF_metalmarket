## 规则引擎实现

```python
class RuleEngine:
    def __init__(self, rule_repo=None):
        self.rule_repo = rule_repo
        self._cache = {}
        self._cache_time = None

    def get_rules(self, category):
        rules = self._load_rules()
        return [r for r in rules if r['category'] == category and r.get('enabled', True)]

    def evaluate(self, rule, context):
        cond = rule['condition']
        field_value = context.get(cond['field'])
        if field_value is None:
            return False
        return self._compare(field_value, cond['operator'], cond['value'])

    def filter(self, decisions, context):
        rules = self.get_rules('action')
        filtered = []
        for decision in decisions:
            blocked = False
            for rule in rules:
                if self._matches_decision(rule, decision) and not self.evaluate(rule, context):
                    blocked = True
                    break
            if not blocked:
                filtered.append(decision)
        return filtered

    def _load_rules(self):
        # 5分钟缓存
        if self._cache and self._cache_time:
            from datetime import datetime, timedelta
            if datetime.now() - self._cache_time < timedelta(minutes=5):
                return self._cache
        if self.rule_repo:
            self._cache = self.rule_repo.get_all_rules()
            self._cache_time = datetime.now()
            return self._cache
        return []

    def _compare(self, field_value, operator, target):
        ops = {
            '>': lambda a, b: a > b,
            '>=': lambda a, b: a >= b,
            '<': lambda a, b: a < b,
            '<=': lambda a, b: a <= b,
            '==': lambda a, b: a == b,
            'in': lambda a, b: a in b,
            'contains': lambda a, b: b in str(a),
        }
        return ops.get(operator, lambda a, b: False)(field_value, target)
```

