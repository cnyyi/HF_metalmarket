```python
class DecisionEngine:
    DECISION_RULES = [
        {
            'condition': lambda ctx: ctx.get('overdue_amount', 0) > 0,
            'type': 'collect_payment',
            'priority': 'high',
            'template': '商户 {merchant_name} 有逾期应收 ¥{overdue_amount:,.2f}，建议催收'
        },
        {
            'condition': lambda ctx: ctx.get('expiring_contracts', 0) > 0,
            'type': 'renew_contract',
            'priority': 'high',
            'template': '{expiring_count} 个合同即将到期，建议跟进续签'
        },
        # ... 更多规则
    ]

    def make(self, memory, risks, forecast, score):
        context = self._build_context(memory, risks, forecast, score)
        decisions = []
        for rule in self.DECISION_RULES:
            if rule['condition'](context):
                decisions.append({
                    'type': rule['type'],
                    'priority': rule['priority'],
                    'message': rule['template'].format(**context),
                    'target': context.get('merchant_id'),
                    'auto_executable': rule.get('auto_executable', False)
                })
        return decisions
```

