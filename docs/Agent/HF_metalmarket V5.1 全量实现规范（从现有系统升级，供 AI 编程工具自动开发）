# 6️⃣ Forecast Engine（V5.1 新增）

---

## 算法

线性回归预测，基于历史月度数据：

```python
class ForecastEngine:
    def run(self, memory, months_ahead=3):
        forecasts = []
        for step_id, data in memory.items():
            if self._is_time_series(data):
                trend = self._linear_forecast(data, months_ahead)
                forecasts.append(trend)
        return forecasts

    def _linear_forecast(self, data, months_ahead):
        # 提取历史值
        values = [item.get('income', item.get('expense', 0)) for item in data]
        months = list(range(len(values)))

        # 最小二乘法线性回归
        n = len(values)
        if n < 2:
            return {'trend': 'insufficient_data', 'confidence': 0}

        sum_x = sum(months)
        sum_y = sum(values)
        sum_xy = sum(x * y for x, y in zip(months, values))
        sum_x2 = sum(x * x for x in months)

        slope = (n * sum_xy - sum_x * sum_y) / (n * sum_x2 - sum_x * sum_x)
        intercept = (sum_y - slope * sum_x) / n

        # 预测未来 N 个月
        predictions = []
        for i in range(months_ahead):
            predicted = slope * (n + i) + intercept
            predictions.append(round(predicted, 2))

        # 置信度：基于 R²
        mean_y = sum_y / n
        ss_tot = sum((y - mean_y) ** 2 for y in values)
        ss_res = sum((y - (slope * x + intercept)) ** 2 for x, y in zip(months, values))
        r_squared = 1 - (ss_res / ss_tot) if ss_tot > 0 else 0

        return {
            'type': 'linear',
            'slope': round(slope, 2),
            'trend': 'up' if slope > 0 else ('down' if slope < 0 else 'flat'),
            'predictions': predictions,
            'confidence': round(r_squared, 2),
            'data_points': n
        }
```

